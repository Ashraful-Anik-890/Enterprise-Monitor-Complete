{
  "name": "enterprise-monitor",
  "version": "5.2.2",
  "description": "Enterprise Employee Monitoring System",
  "main": "dist/main/main.js",
  "author": "Ashraful Anik",
  "license": "PROPRIETARY",
  "scripts": {
    "start": "npm run build && electron .",
    "start:mac": "npm run build:mac && electron .",
    "build": "tsc && npm run copy-assets",
    "copy-assets": "xcopy /Y /I src\\renderer\\index.html dist\\renderer\\ && xcopy /Y src\\renderer\\renderer.js dist\\renderer\\",
    "copy-assets:mac": "cp src/renderer/index.html dist/renderer/ && cp src/renderer/renderer.js dist/renderer/",
    "build:mac": "tsc && npm run copy-assets:mac",
    "watch": "tsc --watch",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder --win --x64",
    "dist:dir": "npm run build && electron-builder --win --x64 --dir",
    "dist:mac": "npm run build:mac && electron-builder --mac --arm64",
    "dist:mac:dir": "npm run build:mac && electron-builder --mac --arm64 --dir"
  },
  "dependencies": {
    "axios": "^1.6.2",
    "electron-store": "^8.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.5",
    "electron": "^40.6.0",
    "electron-builder": "^26.8.1",
    "typescript": "^5.3.3"
  },
  "build": {
    "appId": "com.ashraful.enterprise-monitor",
    "productName": "Enterprise Monitor",
    "copyright": "Developed by Ashraful Anik",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "resources/icon.ico",
      "requestedExecutionLevel": "asInvoker",
      "extraResources": [
        {
          "from": "../backend-windows/dist/enterprise_monitor_backend",
          "to": "backend"
        },
        {
          "from": "resources/",
          "to": "resources/",
          "filter": [
            "**/*",
            "!*.md"
          ]
        }
      ]
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        }
      ],
      "identity": "-",
      "icon": "resources/icon.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "category": "public.app-category.business",
      "extraResources": [
        {
          "from": "../backend-macos/dist/enterprise_monitor_backend",
          "to": "backend"
        },
        {
          "from": "resources/",
          "to": "resources/",
          "filter": [
            "**/*",
            "!*.md"
          ]
        }
      ]
    },
    "dmg": {
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Enterprise Monitor",
      "include": "build/installer.nsh"
    }
  }
}