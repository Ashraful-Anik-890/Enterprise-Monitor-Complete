{
  "name": "enterprise-monitor",
  "version": "5.3.0",
  "description": "Enterprise Employee Monitoring System",
  "main": "dist/main/main.js",
  "author": "Ashraful Anik <ashraful.anik@example.com>",
  "homepage": "https://github.com/Ashraful-Anik-890/Enterprise-Monitor-Complete",
  "license": "PROPRIETARY",
  "scripts": {
    "start": "npm run build && electron . --no-sandbox",
    "start:mac": "npm run build:mac && electron . --no-sandbox",
    "start:linux": "npm run build:linux && electron . --no-sandbox",
    "build": "tsc && npm run copy-assets",
    "copy-assets": "xcopy /Y /I src\\renderer\\index.html dist\\renderer\\ && xcopy /Y src\\renderer\\renderer.js dist\\renderer\\",
    "copy-assets:mac": "cp src/renderer/index.html dist/renderer/ && cp src/renderer/renderer.js dist/renderer/",
    "copy-assets:linux": "cp src/renderer/index.html dist/renderer/ && cp src/renderer/renderer.js dist/renderer/",
    "build:mac": "tsc && npm run copy-assets:mac",
    "build:linux": "tsc && npm run copy-assets:linux",
    "watch": "tsc --watch",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder --win --x64",
    "dist:publish": "npm run build && electron-builder --win --x64 --publish always",
    "dist:dir": "npm run build && electron-builder --win --x64 --dir",
    "dist:mac": "npm run build:mac && electron-builder --mac --arm64",
    "dist:mac:dir": "npm run build:mac && electron-builder --mac --arm64 --dir",
    "dist:linux": "npm run build:linux && electron-builder --linux",
    "dist:linux:dir": "npm run build:linux && electron-builder --linux --dir"
  },
  "dependencies": {
    "axios": "^1.6.2",
    "electron-store": "^8.1.0",
    "electron-updater": "^6.3.9"
  },
  "devDependencies": {
    "@types/node": "^20.10.5",
    "electron": "^40.6.0",
    "electron-builder": "^26.8.1",
    "typescript": "^5.3.3"
  },
  "build": {
    "appId": "com.ashraful.enterprise-monitor",
    "productName": "Enterprise Monitor",
    "copyright": "Developed by Ashraful Anik",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "resources/icon.ico",
      "requestedExecutionLevel": "asInvoker",
      "publish": {
        "provider": "github",
        "owner": "Ashraful-Anik-890",
        "repo": "Enterprise-Monitor-Complete",
        "releaseType": "release"
      },
      "extraResources": [
        {
          "from": "../backend-windows/dist/enterprise_monitor_backend",
          "to": "backend"
        },
        {
          "from": "resources/",
          "to": "resources/",
          "filter": [
            "**/*",
            "!*.md"
          ]
        }
      ]
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        }
      ],
      "identity": "-",
      "icon": "resources/icon.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "category": "public.app-category.business",
      "extendInfo": {
        "NSScreenCaptureUsageDescription": "Enterprise Monitor requires Screen Recording to capture activity screenshots and video.",
        "NSAppleEventsUsageDescription": "Enterprise Monitor requires Automation access to track active browser windows and application context.",
        "NSAccessibilityUsageDescription": "Enterprise Monitor requires Accessibility access to capture window titles and monitor user activity."
      },
      "extraResources": [
        {
          "from": "../backend-macos/dist/enterprise_monitor_backend",
          "to": "backend"
        },
        {
          "from": "resources/",
          "to": "resources/",
          "filter": [
            "**/*",
            "!*.md"
          ]
        }
      ]
    },
    "dmg": {
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Enterprise Monitor",
      "include": "build/installer.nsh",
      "warningsAsErrors": false
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "icon-source.png",
      "category": "Office",
      "extraResources": [
        {
          "from": "../backend-linux/dist/enterprise_monitor_backend",
          "to": "backend"
        },
        {
          "from": "resources/",
          "to": "resources/",
          "filter": [
            "**/*",
            "!*.md"
          ]
        }
      ]
    }
  }
}